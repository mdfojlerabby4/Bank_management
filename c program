struct Account* findAccount(int accNo) {
    struct Account *temp = accountHead;
    while(temp != NULL) {
        if(temp->accNo == accNo) {
            return temp;
        }
        temp = temp->next;
    }
    return NULL;
}

void searchAccount() {
    char searchTerm[100];
    struct Account *temp = accountHead;
    int found = 0;
    int isNumber = 1;

    displayHeader("SEARCH ACCOUNT");
    printf("Enter Account Number OR Name: ");
    fgets(searchTerm, sizeof(searchTerm), stdin);
    searchTerm[strcspn(searchTerm, "\n")] = 0;

    for(int i = 0; searchTerm[i]; i++) {
        if(!isdigit(searchTerm[i])) {
            isNumber = 0;
            break;
        }
    }

    printf("\n");

    if(isNumber) {
        int accNo = atoi(searchTerm);
        struct Account *acc = findAccount(accNo);

        if(acc != NULL) {
            printf("[FOUND] Account Found:\n");
            printf("----------------------------------------\n");
            printf("Account Number : %d\n", acc->accNo);
            printf("Holder Name    : %s\n", acc->name);
            printf("Balance        : %.2f\n", acc->balance);
            printf("Loan Taken     : %.2f\n", acc->loanAmount);
            printf("Loan Remaining : %.2f\n", acc->loanRemaining);
            printf("Active Loan    : %s\n", acc->hasActiveLoan ? "YES" : "NO");
            printf("----------------------------------------\n");
            found = 1;
        }
    } else {
        char searchLower[100];
        strcpy(searchLower, searchTerm);
        toLowercase(searchLower);

        printf("Search Results for '%s':\n", searchTerm);
        printf("%-15s %-30s %-15s %-15s\n", "Account No", "Holder Name", "Balance", "Loan Due");
        printf("--------------------------------------------------------------------------------\n");

        while(temp != NULL) {
            char nameLower[100];
            strcpy(nameLower, temp->name);
            toLowercase(nameLower);

            if(strstr(nameLower, searchLower) != NULL) {
                printf("%-15d %-30s %-15.2f %-15.2f\n",
                       temp->accNo, temp->name, temp->balance, temp->loanRemaining);
                found = 1;
            }
            temp = temp->next;
        }
    }

    if(!found) {
        displayError("No account found matching your search criteria!");
    }

    showExitMenu();
}

void createAccount() {
    struct Account *newAccount = (struct Account*)malloc(sizeof(struct Account));
    struct Account *temp = accountHead;

    displayHeader("CREATE NEW ACCOUNT");

    printf("Enter Account Number: ");
    scanf("%d", &newAccount->accNo);
    clearInputBuffer();

    temp = accountHead;
    while(temp != NULL) {
        if(temp->accNo == newAccount->accNo) {
            displayError("Account number already exists!");
            free(newAccount);
            showExitMenu();
            return;
        }
        temp = temp->next;
    }

    printf("Enter Account Holder Name: ");
    fgets(newAccount->name, sizeof(newAccount->name), stdin);
    newAccount->name[strcspn(newAccount->name, "\n")] = 0;

    newAccount->balance = 0.0;
    newAccount->loanAmount = 0.0;
    newAccount->loanRemaining = 0.0;
    newAccount->loanInterestRate = 0.0;
    newAccount->hasActiveLoan = 0;
    newAccount->next = NULL;

    if(accountHead == NULL) {
        accountHead = newAccount;
    } else {
        temp = accountHead;
        while(temp->next != NULL) {
            temp = temp->next;
        }
        temp->next = newAccount;
    }

    displaySuccess("Account created successfully!");
    printf("\nAccount Details:\n");
    printf("Account Number: %d\n", newAccount->accNo);
    printf("Holder Name: %s\n", newAccount->name);
    printf("Initial Balance: %.2f\n", newAccount->balance);

    showExitMenu();
}

