void addToQueue(int accNo, char *type, float amount, int toAccNo, int priority, float rate, int term) {
    if(priority == 1 || priority == 2) {
        struct PriorityNode *newNode = (struct PriorityNode*)malloc(sizeof(struct PriorityNode));
        struct PriorityNode *temp = priorityFront;
        struct PriorityNode *prev = NULL;

        newNode->requestId = nextRequestId++;
        newNode->accNo = accNo;
        strcpy(newNode->type, type);
        newNode->amount = amount;
        newNode->toAccNo = toAccNo;
        newNode->priority = priority;
        newNode->interestRate = rate;
        newNode->termMonths = term;
        newNode->next = NULL;

        if(priorityFront == NULL) {
            priorityFront = newNode;
        } else {
            while(temp != NULL && temp->priority <= priority) {
                prev = temp;
                temp = temp->next;
            }
            if(prev == NULL) {
                newNode->next = priorityFront;
                priorityFront = newNode;
            } else {
                prev->next = newNode;
                newNode->next = temp;
            }
        }

        char *priorityStr = (priority == 1) ? "HIGH (VIP)" : "MEDIUM";
        printf("[QUEUE] Added to PRIORITY Queue with %s priority (ID: %d)\n", priorityStr, newNode->requestId);
    }
    else {
        struct Request *newRequest = (struct Request*)malloc(sizeof(struct Request));

        newRequest->requestId = nextRequestId++;
        newRequest->accNo = accNo;
        strcpy(newRequest->type, type);
        newRequest->amount = amount;
        newRequest->toAccNo = toAccNo;
        newRequest->interestRate = rate;
        newRequest->termMonths = term;
        newRequest->next = NULL;

        if(requestRear == NULL) {
            requestFront = requestRear = newRequest;
        } else {
            requestRear->next = newRequest;
            requestRear = newRequest;
        }

        printf("[QUEUE] Added to REGULAR Queue (ID: %d)\n", newRequest->requestId);
    }
}

void managePriorityQueue() {
    if(priorityFront == NULL) {
        displayError("No pending priority requests!");
        showExitMenu();
        return;
    }

    displayHeader("PRIORITY QUEUE - PENDING REQUESTS");

    printf("\n%-5s %-10s %-15s %-12s %-10s %-20s\n",
           "ID", "Account", "Type", "Amount", "Priority", "Details");
    printf("--------------------------------------------------------------------------------\n");

    struct PriorityNode *temp = priorityFront;
    while(temp != NULL) {
        char *priorityStr = (temp->priority == 1) ? "HIGH-VIP" : "MEDIUM";

        if(strcmp(temp->type, "TRANSFER") == 0) {
            printf("%-5d %-10d %-15s %-12.2f %-10s To: %d\n",
                   temp->requestId, temp->accNo, temp->type,
                   temp->amount, priorityStr, temp->toAccNo);
        } else if(strcmp(temp->type, "LOAN_APPLICATION") == 0) {
            float totalPayable = calculateTotalPayable(temp->amount, temp->interestRate, temp->termMonths);
            printf("%-5d %-10d %-15s %-12.2f %-10s Loan: %.2f @ %.1f%% (Total: %.2f)\n",
                   temp->requestId, temp->accNo, temp->type,
                   temp->amount, priorityStr, temp->amount, temp->interestRate, totalPayable);
        } else {
            printf("%-5d %-10d %-15s %-12.2f %-10s -\n",
                   temp->requestId, temp->accNo, temp->type,
                   temp->amount, priorityStr);
        }
        temp = temp->next;
    }

    printf("\n========================================\n");
    printf("  Queue Order: First come first serve\n");
    printf("  (Based on Priority then arrival time)\n");
    printf("========================================\n");
    printf("  1. Approve First Request\n");
    printf("  2. Remove First Request\n");
    printf("  3. Back to Main Menu\n");
    printf("========================================\n");
    printf("Enter your choice: ");
    int choice;
    scanf("%d", &choice);
    clearInputBuffer();

    if(choice == 1) {
        struct PriorityNode *current = priorityFront;

        printf("\n--- Processing Request ID: %d ---\n", current->requestId);

        if(strcmp(current->type, "DEPOSIT") == 0) {
            struct Account *acc = findAccount(current->accNo);
            if(acc == NULL) {
                displayError("Account not found!");
            } else {
                acc->balance += current->amount;
                pushTransaction(current->accNo, "DEPOSIT", current->amount, 0);
                displaySuccess("Deposit approved!");
                printf("Account: %s | New Balance: %.2f\n", acc->name, acc->balance);
            }
        }
        else if(strcmp(current->type, "WITHDRAW") == 0) {
            struct Account *acc = findAccount(current->accNo);
            if(acc == NULL) {
                displayError("Account not found!");
            } else if(acc->balance >= current->amount) {
                acc->balance -= current->amount;
                pushTransaction(current->accNo, "WITHDRAW", current->amount, 0);
                displaySuccess("Withdrawal approved!");
                printf("Account: %s | New Balance: %.2f\n", acc->name, acc->balance);
            } else {
                displayError("Insufficient balance! Request rejected.");
            }
        }
        else if(strcmp(current->type, "TRANSFER") == 0) {
            struct Account *fromAcc = findAccount(current->accNo);
            struct Account *toAcc = findAccount(current->toAccNo);

            if(fromAcc == NULL || toAcc == NULL) {
                displayError("Account not found!");
            } else if(fromAcc->balance >= current->amount) {
                fromAcc->balance -= current->amount;
                toAcc->balance += current->amount;
                pushTransaction(current->accNo, "TRANSFER", current->amount, current->toAccNo);
                displaySuccess("Transfer approved!");
                printf("Transferred %.2f from %s to %s\n", current->amount, fromAcc->name, toAcc->name);
            } else {
                displayError("Insufficient balance! Request rejected.");
            }
        }
        else if(strcmp(current->type, "LOAN_APPLICATION") == 0) {
            approveLoan(current->accNo, current->amount, current->interestRate, current->termMonths);
        }
        else if(strcmp(current->type, "LOAN_PAYMENT") == 0) {
            struct Account *acc = findAccount(current->accNo);
            if(acc && acc->hasActiveLoan) {
                if(current->amount <= acc->balance) {
                    acc->balance -= current->amount;

                    if(current->amount <= acc->loanRemaining) {
                        acc->loanRemaining -= current->amount;
                        pushTransaction(current->accNo, "LOAN_PAYMENT", current->amount, 0);
                        displaySuccess("Loan payment approved!");

                        float totalPayable = calculateTotalPayable(acc->loanAmount, acc->loanInterestRate, 12);
                        float paid = totalPayable - acc->loanRemaining;

                        printf("Payment Amount : %.2f\n", current->amount);
                        printf("Remaining Total: %.2f (Principal + Interest)\n", acc->loanRemaining);
                        printf("Total Paid     : %.2f\n", paid);

                        if(acc->loanRemaining <= 0) {
                            acc->hasActiveLoan = 0;
                            acc->loanAmount = 0;
                            acc->loanRemaining = 0;
                            acc->loanInterestRate = 0;
                            printf("[CONGRATULATIONS] LOAN FULLY PAID OFF!\n");
                        }
                    } else {
                        float excess = current->amount - acc->loanRemaining;
                        acc->balance += excess;
                        displayError("Payment amount exceeds remaining loan!");
                        printf("Excess amount %.2f returned to account.\n", excess);
                    }
                } else {
                    displayError("Insufficient balance!");
                }
            } else {
                displayError("No active loan found!");
            }
        }

        priorityFront = current->next;
        free(current);

    } else if(choice == 2) {
        struct PriorityNode *current = priorityFront;
        printf("\nRemoving Request ID: %d\n", current->requestId);
        priorityFront = current->next;
        free(current);
        displaySuccess("Request removed from queue!");
    }

    showExitMenu();
}

void manageRegularQueue() {
    if(requestFront == NULL) {
        displayError("No pending regular requests!");
        showExitMenu();
        return;
    }

    displayHeader("REGULAR QUEUE - PENDING REQUESTS");

    printf("\n%-5s %-10s %-15s %-12s %-20s\n",
           "ID", "Account", "Type", "Amount", "Details");
    printf("--------------------------------------------------------------------------------\n");

    struct Request *temp = requestFront;
    while(temp != NULL) {
        if(strcmp(temp->type, "TRANSFER") == 0) {
            printf("%-5d %-10d %-15s %-12.2f To: %d\n",
                   temp->requestId, temp->accNo, temp->type,
                   temp->amount, temp->toAccNo);
        } else if(strcmp(temp->type, "LOAN_APPLICATION") == 0) {
            float totalPayable = calculateTotalPayable(temp->amount, temp->interestRate, temp->termMonths);
            printf("%-5d %-10d %-15s %-12.2f Loan: %.2f @ %.1f%% (Total: %.2f)\n",
                   temp->requestId, temp->accNo, temp->type,
                   temp->amount, temp->amount, temp->interestRate, totalPayable);
        } else {
            printf("%-5d %-10d %-15s %-12.2f -\n",
                   temp->requestId, temp->accNo, temp->type,
                   temp->amount);
        }
        temp = temp->next;
    }

    printf("\n========================================\n");
    printf("  Queue Order: First come first serve\n");
    printf("========================================\n");
    printf("  1. Approve First Request\n");
    printf("  2. Remove First Request\n");
    printf("  3. Back to Main Menu\n");
    printf("========================================\n");
    printf("Enter your choice: ");
    int choice;
    scanf("%d", &choice);
    clearInputBuffer();

    if(choice == 1) {
        struct Request *current = requestFront;

        printf("\n--- Processing Request ID: %d ---\n", current->requestId);

        if(strcmp(current->type, "DEPOSIT") == 0) {
            struct Account *acc = findAccount(current->accNo);
            if(acc == NULL) {
                displayError("Account not found!");
            } else {
                acc->balance += current->amount;
                pushTransaction(current->accNo, "DEPOSIT", current->amount, 0);
                displaySuccess("Deposit approved!");
                printf("Account: %s | New Balance: %.2f\n", acc->name, acc->balance);
            }
        }
        else if(strcmp(current->type, "WITHDRAW") == 0) {
            struct Account *acc = findAccount(current->accNo);
            if(acc == NULL) {
                displayError("Account not found!");
            } else if(acc->balance >= current->amount) {
                acc->balance -= current->amount;
                pushTransaction(current->accNo, "WITHDRAW", current->amount, 0);
                displaySuccess("Withdrawal approved!");
                printf("Account: %s | New Balance: %.2f\n", acc->name, acc->balance);
            } else {
                displayError("Insufficient balance! Request rejected.");
            }
        }
        else if(strcmp(current->type, "TRANSFER") == 0) {
            struct Account *fromAcc = findAccount(current->accNo);
            struct Account *toAcc = findAccount(current->toAccNo);

            if(fromAcc == NULL || toAcc == NULL) {
                displayError("Account not found!");
            } else if(fromAcc->balance >= current->amount) {
                fromAcc->balance -= current->amount;
                toAcc->balance += current->amount;
                pushTransaction(current->accNo, "TRANSFER", current->amount, current->toAccNo);
                displaySuccess("Transfer approved!");
                printf("Transferred %.2f from %s to %s\n", current->amount, fromAcc->name, toAcc->name);
            } else {
                displayError("Insufficient balance! Request rejected.");
            }
        }
        else if(strcmp(current->type, "LOAN_APPLICATION") == 0) {
            approveLoan(current->accNo, current->amount, current->interestRate, current->termMonths);
        }
        else if(strcmp(current->type, "LOAN_PAYMENT") == 0) {
            struct Account *acc = findAccount(current->accNo);
            if(acc && acc->hasActiveLoan) {
                if(current->amount <= acc->balance) {
                    acc->balance -= current->amount;

                    if(current->amount <= acc->loanRemaining) {
                        acc->loanRemaining -= current->amount;
                        pushTransaction(current->accNo, "LOAN_PAYMENT", current->amount, 0);
                        displaySuccess("Loan payment approved!");

                        float totalPayable = calculateTotalPayable(acc->loanAmount, acc->loanInterestRate, 12);
                        float paid = totalPayable - acc->loanRemaining;

                        printf("Payment Amount : %.2f\n", current->amount);
                        printf("Remaining Total: %.2f (Principal + Interest)\n", acc->loanRemaining);
                        printf("Total Paid     : %.2f\n", paid);

                        if(acc->loanRemaining <= 0) {
                            acc->hasActiveLoan = 0;
                            acc->loanAmount = 0;
                            acc->loanRemaining = 0;
                            acc->loanInterestRate = 0;
                            printf("[CONGRATULATIONS] LOAN FULLY PAID OFF!\n");
                        }
                    } else {
                        float excess = current->amount - acc->loanRemaining;
                        acc->balance += excess;
                        displayError("Payment amount exceeds remaining loan!");
                        printf("Excess amount %.2f returned to account.\n", excess);
                    }
                } else {
                    displayError("Insufficient balance!");
                }
            } else {
                displayError("No active loan found!");
            }
        }

        requestFront = current->next;
        if(requestFront == NULL) {
            requestRear = NULL;
        }
        free(current);

    } else if(choice == 2) {
        struct Request *current = requestFront;
        printf("\nRemoving Request ID: %d\n", current->requestId);
        requestFront = current->next;
        if(requestFront == NULL) {
            requestRear = NULL;
        }
        free(current);
        displaySuccess("Request removed from queue!");
    }

    showExitMenu();
}

float calculateEMI(float principal, float rate, int months) {
    float monthlyRate = rate / 12 / 100;
    if(monthlyRate == 0) return principal / months;
    float emi = principal * monthlyRate * pow(1 + monthlyRate, months) / (pow(1 + monthlyRate, months) - 1);
    return emi;
}

float calculateTotalPayable(float principal, float rate, int months) {
    float emi = calculateEMI(principal, rate, months);
    return emi * months;
}

void approveLoan(int accNo, float amount, float interestRate, int term) {
    struct Account *acc = findAccount(accNo);
    if(acc == NULL) {
        displayError("Account not found!");
        return;
    }

    if(acc->hasActiveLoan) {
        displayError("Account already has an active loan!");
        return;
    }

    if(acc->balance < amount * 0.1) {
        displayError("Loan REJECTED: Insufficient balance!");
        printf("Need at least 10%% of loan amount (%.2f) in account\n", amount * 0.1);
        return;
    }

    float emi = calculateEMI(amount, interestRate, term);
    float totalPayable = emi * term;
    float totalInterest = totalPayable - amount;

    acc->loanAmount = amount;
    acc->loanRemaining = totalPayable;
    acc->loanInterestRate = interestRate;
    acc->hasActiveLoan = 1;

    struct Loan *newLoan = (struct Loan*)malloc(sizeof(struct Loan));
    newLoan->loanId = nextLoanId++;
    newLoan->accNo = accNo;
    newLoan->principalAmount = amount;
    newLoan->remainingAmount = totalPayable;
    newLoan->interestRate = interestRate;
    newLoan->termMonths = term;
    newLoan->monthsPaid = 0;
    newLoan->emiAmount = emi;
    strcpy(newLoan->status, "ACTIVE");
    newLoan->next = loanHead;
    loanHead = newLoan;

    acc->balance += amount;
    pushTransaction(accNo, "LOAN_DISBURSEMENT", amount, 0);

    printf("\n========================================\n");
    printf("[APPROVED] LOAN APPROVED for %s!\n", acc->name);
    printf("========================================\n");
    printf("Principal Amount : %.2f\n", amount);
    printf("Interest Rate    : %.2f%%\n", interestRate);
    printf("Term             : %d months\n", term);
    printf("Monthly EMI      : %.2f\n", emi);
    printf("----------------------------------------\n");
    printf("Total Interest   : %.2f\n", totalInterest);
    printf("Total Payable    : %.2f\n", totalPayable);
    printf("----------------------------------------\n");
    printf("Amount Disbursed : %.2f\n", amount);
    printf("New Balance      : %.2f\n", acc->balance);
    printf("========================================\n");
}

void applyForLoan() {
    int accNo;
    float amount;
    int term;
    float rate;
    int priority;

    displayHeader("APPLY FOR LOAN");
    printf("Enter Account Number: ");
    scanf("%d", &accNo);
    clearInputBuffer();

    struct Account *acc = findAccount(accNo);
    if(acc == NULL) {
        displayError("Account not found!");
        showExitMenu();
        return;
    }

    printf("Account Holder: %s\n", acc->name);
    printf("Current Balance: %.2f\n", acc->balance);

    if(acc->hasActiveLoan) {
        displayError("You already have an active loan!");
        printf("Remaining amount: %.2f\n", acc->loanRemaining);
        showExitMenu();
        return;
    }

    printf("Enter Loan Amount: ");
    scanf("%f", &amount);
    printf("Enter Loan Term (months, max 60): ");
    scanf("%d", &term);
    printf("Enter Interest Rate (%% per annum): ");
    scanf("%f", &rate);

    if(amount <= 0 || term <= 0 || term > 60 || rate <= 0) {
        displayError("Invalid loan parameters!");
        showExitMenu();
        return;
    }

    printf("\nPriority (1=High/VIP, 2=Medium, 3=Normal): ");
    scanf("%d", &priority);

    float emi = calculateEMI(amount, rate, term);
    float totalPayable = emi * term;
    float totalInterest = totalPayable - amount;

    printf("\n========================================\n");
    printf("      LOAN APPLICATION SUMMARY\n");
    printf("========================================\n");
    printf("Principal Amount: %.2f\n", amount);
    printf("Interest Rate   : %.2f%%\n", rate);
    printf("Term            : %d months\n", term);
    printf("Monthly EMI     : %.2f\n", emi);
    printf("----------------------------------------\n");
    printf("Total Interest  : %.2f\n", totalInterest);
    printf("Total Payable   : %.2f\n", totalPayable);
    printf("========================================\n");

    printf("\nConfirm loan application? (1=Yes, 0=No): ");
    int confirm;
    scanf("%d", &confirm);

    if(confirm == 1) {
        addToQueue(accNo, "LOAN_APPLICATION", amount, 0, priority, rate, term);

        if(priority == 3) {
            displaySuccess("Loan application added to Regular Queue!");
        } else {
            displaySuccess("Loan application added to Priority Queue!");
        }
        printf("Please process the request from queue to approve the loan.\n");
    } else {
        printf("Loan application cancelled.\n");
    }

    showExitMenu();
}

void makeLoanPayment() {
    int accNo;
    float amount;
    int priority;

    displayHeader("MAKE LOAN PAYMENT");
    printf("Enter Account Number: ");
    scanf("%d", &accNo);
    clearInputBuffer();

    struct Account *acc = findAccount(accNo);
    if(acc == NULL) {
        displayError("Account not found!");
        showExitMenu();
        return;
    }

    if(!acc->hasActiveLoan) {
        displayError("No active loan found for this account!");
        showExitMenu();
        return;
    }

    float totalPayable = acc->loanRemaining;
    float principalAmount = acc->loanAmount;
    float totalInterest = totalPayable - principalAmount;
    float paid = (calculateTotalPayable(principalAmount, acc->loanInterestRate, 12)) - totalPayable;

    printf("Account Holder: %s\n", acc->name);
    printf("Current Balance: %.2f\n", acc->balance);
    printf("========================================\n");
    printf("Principal Amount: %.2f\n", principalAmount);
    printf("Interest Rate   : %.2f%%\n", acc->loanInterestRate);
    printf("Total Interest  : %.2f\n", totalInterest);
    printf("Total Payable   : %.2f\n", totalPayable);
    printf("Paid Amount     : %.2f\n", paid);
    printf("Remaining       : %.2f\n", totalPayable);
    printf("========================================\n");
    printf("Enter Payment Amount: ");
    scanf("%f", &amount);

    if(amount <= 0) {
        displayError("Invalid amount!");
        showExitMenu();
        return;
    }

    if(amount > acc->balance) {
        displayError("Insufficient balance!");
        showExitMenu();
        return;
    }

    printf("\nPriority (1=High/VIP, 2=Medium, 3=Normal): ");
    scanf("%d", &priority);

    addToQueue(accNo, "LOAN_PAYMENT", amount, 0, priority, 0, 0);

    if(priority == 3) {
        displaySuccess("Loan payment request added to Regular Queue!");
    } else {
        displaySuccess("Loan payment request added to Priority Queue!");
    }
    showExitMenu();
}

void checkLoanStatus() {
    int accNo;

    displayHeader("CHECK LOAN STATUS");
    printf("Enter Account Number: ");
    scanf("%d", &accNo);
    clearInputBuffer();

    struct Account *acc = findAccount(accNo);
    if(acc == NULL) {
        displayError("Account not found!");
        showExitMenu();
        return;
    }

    printf("\n========================================\n");
    printf("         LOAN STATUS\n");
    printf("========================================\n");
    printf("Account Holder: %s\n", acc->name);
    printf("Account Number: %d\n", acc->accNo);
    printf("----------------------------------------\n");

    if(acc->hasActiveLoan) {
        float totalPayable = acc->loanRemaining;
        float principalAmount = acc->loanAmount;
        float totalInterest = totalPayable - principalAmount;
        float paid = (calculateTotalPayable(principalAmount, acc->loanInterestRate, 12)) - totalPayable;
        float progress = (paid / calculateTotalPayable(principalAmount, acc->loanInterestRate, 12)) * 100;

        printf("Status          : ACTIVE\n");
        printf("Principal Amount: %.2f\n", principalAmount);
        printf("Interest Rate   : %.2f%%\n", acc->loanInterestRate);
        printf("Total Interest  : %.2f\n", totalInterest);
        printf("Total Payable   : %.2f\n", totalPayable);
        printf("----------------------------------------\n");
        printf("Paid Amount     : %.2f\n", paid);
        printf("Remaining       : %.2f\n", totalPayable);
        printf("Progress        : %.1f%%\n", progress);
    } else {
        printf("Status         : NO ACTIVE LOAN\n");
        if(acc->loanAmount > 0) {
            printf("Previous Loan  : FULLY PAID\n");
            printf("Total Paid     : %.2f\n", acc->loanAmount);
        }
    }
    printf("========================================\n");

    showExitMenu();
}

