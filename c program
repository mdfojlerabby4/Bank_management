void pushTransaction(int accNo, char *type, float amount, int toAccNo) {
    struct Transaction *newTrans = (struct Transaction*)malloc(sizeof(struct Transaction));

    newTrans->transactionId = nextTransactionId++;
    newTrans->accNo = accNo;
    strcpy(newTrans->type, type);
    newTrans->amount = amount;
    newTrans->toAccNo = toAccNo;
    newTrans->next = transactionTop;
    transactionTop = newTrans;
}

void displayRecentTransactions() {
    struct Transaction *temp = transactionTop;
    int count = 0;

    displayHeader("RECENT TRANSACTIONS (Last 5)");

    if(temp == NULL) {
        displayError("No transactions found!");
        showExitMenu();
        return;
    }

    printf("%-5s %-10s %-15s %-12s %-20s\n", "ID", "Account", "Type", "Amount", "Details");
    printf("--------------------------------------------------------------------------------\n");

    while(temp != NULL && count < 5) {
        struct Account *acc = findAccount(temp->accNo);
        char *holderName = (acc != NULL) ? acc->name : "Unknown";

        if(strcmp(temp->type, "TRANSFER") == 0) {
            struct Account *toAcc = findAccount(temp->toAccNo);
            char *toName = (toAcc != NULL) ? toAcc->name : "Unknown";
            printf("%-5d %-10d %-15s %-12.2f To: %d (%s)\n",
                   temp->transactionId, temp->accNo, temp->type,
                   temp->amount, temp->toAccNo, toName);
        } else {
            printf("%-5d %-10d %-15s %-12.2f %s\n",
                   temp->transactionId, temp->accNo, temp->type,
                   temp->amount, holderName);
        }
        temp = temp->next;
        count++;
    }

    showExitMenu();
}

void undoLastTransaction() {
    if(transactionTop == NULL) {
        displayError("No transactions to undo!");
        showExitMenu();
        return;
    }

    struct Transaction *lastTrans = transactionTop;

    displayHeader("UNDO LAST TRANSACTION");

    if(strcmp(lastTrans->type, "DEPOSIT") == 0) {
        struct Account *acc = findAccount(lastTrans->accNo);
        if(acc != NULL) {
            acc->balance -= lastTrans->amount;
            printf("[UNDO] Undid deposit of %.2f for %s\n", lastTrans->amount, acc->name);
        }
    }
    else if(strcmp(lastTrans->type, "WITHDRAW") == 0) {
        struct Account *acc = findAccount(lastTrans->accNo);
        if(acc != NULL) {
            acc->balance += lastTrans->amount;
            printf("[UNDO] Undid withdrawal of %.2f for %s\n", lastTrans->amount, acc->name);
        }
    }
    else if(strcmp(lastTrans->type, "TRANSFER") == 0) {
        struct Account *fromAcc = findAccount(lastTrans->accNo);
        struct Account *toAcc = findAccount(lastTrans->toAccNo);

        if(fromAcc != NULL && toAcc != NULL) {
            fromAcc->balance += lastTrans->amount;
            toAcc->balance -= lastTrans->amount;
            printf("[UNDO] Undid transfer of %.2f from %s to %s\n",
                   lastTrans->amount, fromAcc->name, toAcc->name);
        }
    }
    else if(strcmp(lastTrans->type, "LOAN_DISBURSEMENT") == 0) {
        struct Account *acc = findAccount(lastTrans->accNo);
        if(acc != NULL) {
            acc->balance -= lastTrans->amount;
            acc->hasActiveLoan = 0;
            acc->loanAmount = 0;
            acc->loanRemaining = 0;
            printf("[UNDO] Undid loan disbursement of %.2f for %s\n", lastTrans->amount, acc->name);
        }
    }
    else if(strcmp(lastTrans->type, "LOAN_PAYMENT") == 0) {
        struct Account *acc = findAccount(lastTrans->accNo);
        if(acc != NULL) {
            acc->balance += lastTrans->amount;
            acc->loanRemaining += lastTrans->amount;
            printf("[UNDO] Undid loan payment of %.2f for %s\n", lastTrans->amount, acc->name);
        }
    }

    transactionTop = lastTrans->next;
    free(lastTrans);
    displaySuccess("Last transaction undone successfully!");
    showExitMenu();
}

