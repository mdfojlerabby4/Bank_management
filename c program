void clearInputBuffer() {
    int c;
    while ((c = getchar()) != '\n' && c != EOF);
}

void toLowercase(char *str) {
    for(int i = 0; str[i]; i++) {
        str[i] = tolower(str[i]);
    }
}

void displayHeader(char *title) {
    printf("\n========================================\n");
