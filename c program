void deleteAccount() {
    int accNo;
    struct Account *temp = accountHead;
    struct Account *prev = NULL;

    displayHeader("DELETE ACCOUNT");
    printf("Enter Account Number to delete: ");
    scanf("%d", &accNo);
    clearInputBuffer();

    if(accountHead == NULL) {
        displayError("No accounts found!");
        showExitMenu();
        return;
    }

    while(temp != NULL && temp->accNo != accNo) {
        prev = temp;
        temp = temp->next;
    }

    if(temp == NULL) {
        displayError("Account not found!");
        showExitMenu();
        return;
    }

    printf("\nAccount to delete:\n");
    printf("Account: %d | Name: %s | Balance: %.2f\n",
           temp->accNo, temp->name, temp->balance);

    if(temp->balance > 0 || temp->hasActiveLoan) {
        printf("\n[WARNING] Account has balance of %.2f and loan remaining: %.2f\n",
               temp->balance, temp->loanRemaining);
        printf("Are you sure you want to delete? (1=Yes, 0=No): ");
        int choice;
        scanf("%d", &choice);
        clearInputBuffer();
        if(choice != 1) {
            printf("Account deletion cancelled.\n");
            showExitMenu();
            return;
        }
    }

    if(prev == NULL) {
        accountHead = temp->next;
    } else {
        prev->next = temp->next;
    }

    displaySuccess("Account deleted successfully!");
    free(temp);
    showExitMenu();
}

